@startuml
!pragma layout smetana
hide empty description
title Navigationsdiagram - Fog Carport

[*] --> Forside

state Forside

state "Carport type" as CarportType {
    state CarportFlatTag
    state CarportHøjRejsning
}

Forside --> Login_Registrer : Klik Fog Konto
Forside --> CarportFlatTag
Forside --> CarportHøjRejsning

CarportFlatTag --> OrdreBekræftelse : indsend ordre
CarportFlatTag --> Login_Registrer

CarportHøjRejsning --> OrdreBekræftelse : indsend ordre
CarportHøjRejsning --> Login_Registrer

state OrdreBekræftelse
OrdreBekræftelse --> Forside

state Login_Registrer
Login_Registrer --> Login_Registrer : Login fejl / bruger oprettet
Login_Registrer --> MineOrdre : Kunde login succes
Login_Registrer --> MedarbejderSide : Medarbejder login succes

state "Bruger login" as BrugerLogin {
    state MineOrdre
    MineOrdre --> Betal
    MineOrdre --> Forside
    MineOrdre --> KundeManual : Betalt
    MineOrdre --> BetaltBekræftelse : Betaling succes

    state BetaltBekræftelse
    BetaltBekræftelse --> MineOrdre

    state Betal
    Betal --> MineOrdre
}

state "Medarbejder login" as MedarbejderLogin {
    state MedarbejderSide
    MedarbejderSide --> Forside
    MedarbejderSide --> MedarbejderManual
    MedarbejderSide --> Rediger

    state SeManual
    SeManual --> MedarbejderSide

    state Rediger
    Rediger --> MedarbejderSide
    Rediger --> Rediger : Opdater mål / pris
}

@enduml