@startuml
title Domænemodel - Fog Carport

class Kunde {
    navn
    email
    telefon
}

class Sælger {
    navn
    email
}

class Forespørgsel

class Konfiguration {
    længde
    bredde
    tagtype
}

class Tilbud {
    pris
    dato
}

class Ordre {
    status
    dato
}

class Stykliste

class Betaling {
    betalingsdato
    beløb
}

Kunde "1" -- "0..*" Forespørgsel
Forespørgsel "1" -- "1" Konfiguration

Sælger "1" -- "0..*" Tilbud
Konfiguration "1" -- "0..1" Tilbud

Tilbud "1" -- "1" Stykliste
Tilbud "1" -- "0..1" Ordre

Ordre "1" -- "0..1" Betaling
Sælger "1" -- "0..*" Ordre
Kunde "1" -- "0..*" Ordre

@enduml